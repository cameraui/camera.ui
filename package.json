{
  "name": "@camera.ui/monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "camera.ui",
  "author": "seydx (https://github.com/cameraui/camera.ui)",
  "type": "module",
  "scripts": {
    "audit": "npm audit fix && tsx ./scripts/audit.ts",
    "build": "tsx ./scripts/build.ts",
    "bundle": "tsx ./scripts/bundle.ts",
    "format": "tsx ./scripts/format.ts",
    "install-updates": "npm i --save && tsx ./scripts/install.ts",
    "lint": "tsx ./scripts/lint.ts",
    "link:python": "node ./scripts/link-python-tools.mjs",
    "presetup": "npm install",
    "release": "tsx ./scripts/release.ts",
    "setup": "tsx ./scripts/setup.ts",
    "update": "updates --update ./ && cupdate && tsx ./scripts/update.ts"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "chalk": "^5.6.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "updates": "^17.18.2"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ora": "^9.4.1"
  }
}
